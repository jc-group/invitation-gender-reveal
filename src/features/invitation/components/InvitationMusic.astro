---
const audioSrc = '/assets/invitation/audio/background-music.mp3';
---

<div class="music-control" data-music-control>
  <audio
    class="music-control__audio"
    src={audioSrc}
    preload="auto"
    loop
    playsinline
    data-music-audio
  ></audio>

  <button
    class="music-control__button"
    type="button"
    aria-label="Activar música"
    data-music-toggle
  >
    <span class="music-control__icon" aria-hidden="true">♪</span>
    <span class="music-control__text" data-music-label>Música</span>
  </button>
</div>

<script is:inline>
  (function() {
    var MUSIC_SESSION_KEY = 'genderRevealMusicStarted';

    var audio = document.querySelector('[data-music-audio]');
    var toggleButton = document.querySelector('[data-music-toggle]');
    var label = document.querySelector('[data-music-label]');

    if (!audio || !toggleButton || !label) return;

    var isPlaying = false;

    function safeSessionGet(key) {
      try {
        return window.sessionStorage.getItem(key);
      } catch {
        return null;
      }
    }

    function safeSessionSet(key, value) {
      try {
        window.sessionStorage.setItem(key, value);
      } catch {}
    }

    function safeSessionRemove(key) {
      try {
        window.sessionStorage.removeItem(key);
      } catch {}
    }

    function updateUi() {
      toggleButton.classList.toggle('is-playing', isPlaying);
      toggleButton.setAttribute(
        'aria-label',
        isPlaying ? 'Pausar música' : 'Activar música'
      );
      label.textContent = isPlaying ? 'Pausar' : 'Música';
    }

    function updateButtonState(playing) {
      isPlaying = playing;
      updateUi();
    }

    function removeUnlockListeners() {
      window.removeEventListener('pointerdown', handleFirstInteraction);
      window.removeEventListener('touchstart', handleFirstInteraction);
      window.removeEventListener('keydown', handleFirstInteraction);
    }

    async function tryPlayMusic() {
      try {
        audio.volume = 0.55;
        await audio.play();
        safeSessionSet(MUSIC_SESSION_KEY, 'true');
        updateButtonState(true);
        removeUnlockListeners();
        return true;
      } catch (err) {
        updateButtonState(false);
        return false;
      }
    }

    function handleFirstInteraction() {
      tryPlayMusic();
    }

    function addUnlockListeners() {
      var options = { once: true, passive: true };
      window.addEventListener('pointerdown', handleFirstInteraction, options);
      window.addEventListener('touchstart', handleFirstInteraction, options);
      window.addEventListener('keydown', handleFirstInteraction, options);
    }

    toggleButton.addEventListener('click', async function() {
      if (isPlaying) {
        audio.pause();
        safeSessionRemove(MUSIC_SESSION_KEY);
        updateButtonState(false);
        return;
      }

      var started = await tryPlayMusic();
      if (!started) {
        addUnlockListeners();
      }
    });

    audio.load();

    var wasStarted = safeSessionGet(MUSIC_SESSION_KEY) === 'true';

    if (wasStarted) {
      tryPlayMusic();
    } else {
      tryPlayMusic().then(function(started) {
        if (!started) {
          addUnlockListeners();
        }
      });
    }

    updateUi();
  })();
</script>