---
import type { Invitation } from '../invitation.types';

type Props = {
  invitation: Invitation;
};

const { invitation } = Astro.props;

const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
---

<section class="rsvp scroll-reveal" data-scroll-reveal aria-label="Confirmar asistencia">
  <p class="rsvp__eyebrow">RSVP</p>

  <h2 class="rsvp__title">
    Confirma tu asistencia
  </h2>

  <p class="rsvp__text">
    {invitation.rsvp.deadline}
  </p>

  <form
    class="rsvp-form"
    data-rsvp-form
    data-supabase-url={supabaseUrl}
    data-supabase-anon-key={supabaseAnonKey}
  >
    <label class="rsvp-form__field">
      <span>Nombre</span>
      <input
        type="text"
        name="name"
        autocomplete="name"
        required
        placeholder="Tu nombre"
      />
    </label>

    <label class="rsvp-form__field">
      <span>¿Asistirás?</span>
      <select name="attendance" required>
        <option value="">Selecciona una opción</option>
        <option value="Sí asistiré">Sí asistiré</option>
        <option value="No podré asistir">No podré asistir</option>
      </select>
    </label>

    <label class="rsvp-form__field">
      <span>Número de personas</span>
      <input
        type="number"
        name="guests"
        min="1"
        max="10"
        value="1"
        required
      />
    </label>

    <fieldset class="rsvp-form__fieldset">
      <legend>Tu predicción</legend>

      <label>
        <input type="radio" name="prediction" value="Niña" required />
        <span>Niña</span>
      </label>

      <label>
        <input type="radio" name="prediction" value="Niño" required />
        <span>Niño</span>
      </label>
    </fieldset>

    <label class="rsvp-form__field">
      <span>Teléfono</span>
      <input
        type="tel"
        name="phone"
        autocomplete="tel"
        placeholder="844..."
        required
      />
    </label>

    <label class="rsvp-form__field">
      <span>Mensaje</span>
      <textarea
        name="message"
        rows="3"
        placeholder="Déjanos un mensaje"
      ></textarea>
      <span class="rsvp-form__hint">Si nos dejas un mensaje, podremos mostrarlo con cariño en la sección de Predicciones en vivo el día del evento.</span>
    </label>

    <button class="rsvp__button" type="submit" data-rsvp-submit>
      Confirmar asistencia
    </button>

    <p class="rsvp-form__status" data-rsvp-status aria-live="polite"></p>
  </form>

  <section class="rsvp-result" data-rsvp-result hidden>
    <span class="rsvp-result__sparkle" aria-hidden="true"></span>
    <h3 class="rsvp-result__title">Gracias por confirmar</h3>
    <p class="rsvp-result__text">Nos emociona compartir este momento contigo.</p>
  </section>
</section>

<script is:inline>
  (function() {
    var RSVP_STORAGE_KEY = 'genderRevealRsvpSubmitted';
    var LIVE_VOTES_SELECTOR = '#predicciones-en-vivo';

    var form = document.querySelector('[data-rsvp-form]');
    var statusElement = document.querySelector('[data-rsvp-status]');
    var submitButton = document.querySelector('[data-rsvp-submit]');
    var resultElement = document.querySelector('[data-rsvp-result]');

    if (!form || !statusElement || !submitButton || !resultElement) return;

    var supabaseUrl = form.getAttribute('data-supabase-url');
    var supabaseAnonKey = form.getAttribute('data-supabase-anon-key');

    function getStoredRsvp() {
      try {
        var raw = window.localStorage.getItem(RSVP_STORAGE_KEY);
        return raw ? JSON.parse(raw) : null;
      } catch (e) {
        return null;
      }
    }

    function setStoredRsvp(prediction) {
      try {
        window.localStorage.setItem(
          RSVP_STORAGE_KEY,
          JSON.stringify({
            submitted: true,
            submittedAt: new Date().toISOString(),
            prediction: prediction
          })
        );
      } catch (e) {}
    }

    function scrollToLiveVotes() {
      var target = document.querySelector(LIVE_VOTES_SELECTOR);
      if (!target) return;
      var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      target.scrollIntoView({
        behavior: prefersReduced ? 'auto' : 'smooth',
        block: 'start'
      });
    }

    function showAlreadySubmitted() {
      form.hidden = true;
      resultElement.hidden = false;
      resultElement.dataset.state = 'success';
      resultElement.innerHTML =
        '<span class="rsvp-result__sparkle" aria-hidden="true"></span>' +
        '<strong>Ya registramos tu respuesta</strong>' +
        '<span>Desde este dispositivo ya se envió una confirmación. Puedes revisar cómo van las predicciones en vivo.</span>' +
        '<button class="rsvp-result__link" type="button" data-scroll-live-votes>Ver predicciones en vivo</button>';
      var liveVotesButton = resultElement.querySelector('[data-scroll-live-votes]');
      if (liveVotesButton) {
        liveVotesButton.addEventListener('click', scrollToLiveVotes);
      }
    }

    var storedRsvp = getStoredRsvp();
    if (storedRsvp?.submitted) {
      showAlreadySubmitted();
      return;
    }

    form.addEventListener('submit', async function(event) {
      event.preventDefault();

      if (getStoredRsvp()?.submitted) {
        statusElement.textContent = 'Desde este dispositivo ya se envió una confirmación.';
        statusElement.dataset.state = 'error';
        scrollToLiveVotes();
        return;
      }

      if (!supabaseUrl || !supabaseAnonKey) {
        statusElement.textContent = 'Falta configurar Supabase.';
        statusElement.dataset.state = 'error';
        return;
      }

      var name = form.querySelector('[name="name"]').value;
      var attendance = form.querySelector('[name="attendance"]').value;
      var guests = form.querySelector('[name="guests"]').value;
      var prediction = form.querySelector('[name="prediction"]:checked') ? form.querySelector('[name="prediction"]:checked').value : '';
      var phone = form.querySelector('[name="phone"]').value;
      var message = form.querySelector('[name="message"]').value;

      if (!name || !attendance || !prediction || !phone) {
        statusElement.textContent = 'Completa los campos obligatorios.';
        statusElement.dataset.state = 'error';
        return;
      }

      var guestsValue = Number(guests);
      if (!Number.isInteger(guestsValue) || guestsValue < 1 || guestsValue > 10) {
        statusElement.textContent = 'El número de personas debe estar entre 1 y 10.';
        statusElement.dataset.state = 'error';
        return;
      }

      submitButton.disabled = true;
        statusElement.textContent = 'Guardando confirmación...';
      statusElement.dataset.state = 'loading';

      try {
        var response = await fetch(supabaseUrl + '/rest/v1/rsvps', {
          method: 'POST',
          headers: {
            'apikey': supabaseAnonKey,
            'Authorization': 'Bearer ' + supabaseAnonKey,
            'Content-Type': 'application/json',
            'Prefer': 'return=minimal'
          },
          body: JSON.stringify({
            event: 'Gender Reveal Catherine & Josafat',
            name: name,
            attendance: attendance,
            guests: guestsValue,
            prediction: prediction,
            phone: phone || null,
            message: message || null,
            user_agent: navigator.userAgent,
            source: 'invitation-web'
          })
        });

        if (!response.ok) {
          throw new Error('Supabase error ' + response.status);
        }

        setStoredRsvp(prediction);

        form.reset();
        form.hidden = true;
        resultElement.hidden = false;
        window.dispatchEvent(new CustomEvent('rsvp:submitted'));

        window.setTimeout(scrollToLiveVotes, 350);
      } catch (err) {
        console.error(err);
        statusElement.textContent = 'No se pudo guardar. Intenta de nuevo.';
        statusElement.dataset.state = 'error';
      } finally {
        submitButton.disabled = false;
      }
    });
  })();
</script>
