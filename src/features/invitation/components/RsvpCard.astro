---
import type { Invitation } from '../invitation.types';

type Props = {
  invitation: Invitation;
};

const { invitation } = Astro.props;
---

<section class="rsvp scroll-reveal" data-scroll-reveal aria-label="Confirmar asistencia">
  <p class="rsvp__eyebrow">RSVP</p>

  <h2 class="rsvp__title">
    Confirma tu asistencia
  </h2>

  <p class="rsvp__text">
    {invitation.rsvp.deadline}
  </p>

  <form class="rsvp-form" data-rsvp-form>
    <label class="rsvp-form__field">
      <span>Nombre</span>
      <input
        type="text"
        name="name"
        autocomplete="name"
        required
        placeholder="Tu nombre"
      />
    </label>

    <label class="rsvp-form__field">
      <span>¿Asistirás?</span>
      <select name="attendance" required>
        <option value="">Selecciona una opción</option>
        <option value="Sí asistiré">Sí asistiré</option>
        <option value="No podré asistir">No podré asistir</option>
      </select>
    </label>

    <label class="rsvp-form__field">
      <span>Número de personas</span>
      <input
        type="number"
        name="guests"
        min="1"
        max="10"
        value="1"
        required
      />
    </label>

    <fieldset class="rsvp-form__fieldset">
      <legend>Tu predicción</legend>

      <label>
        <input type="radio" name="prediction" value="Niña" required />
        <span>Niña</span>
      </label>

      <label>
        <input type="radio" name="prediction" value="Niño" required />
        <span>Niño</span>
      </label>
    </fieldset>

    <label class="rsvp-form__field">
      <span>Teléfono opcional</span>
      <input
        type="tel"
        name="phone"
        autocomplete="tel"
        placeholder="844..."
      />
    </label>

    <label class="rsvp-form__field">
      <span>Mensaje opcional</span>
      <textarea
        name="message"
        rows="3"
        placeholder="Déjanos un mensaje"
      ></textarea>
    </label>

    <button class="rsvp__button" type="submit" data-rsvp-submit>
      Confirmar asistencia
    </button>

    <p class="rsvp-form__status" data-rsvp-status aria-live="polite"></p>
  </form>

  <div class="rsvp-success" data-rsvp-success hidden>
    <p class="rsvp-success__icon">🎉</p>
    <h3 class="rsvp-success__title">Gracias por confirmar</h3>
    <p class="rsvp-success__text">Nos emociona compartir este momento contigo.</p>
  </div>
</section>

<script is:inline>
  (function() {
    var form = document.querySelector('[data-rsvp-form]');
    var statusElement = document.querySelector('[data-rsvp-status]');
    var submitButton = document.querySelector('[data-rsvp-submit]');

    if (!form || !statusElement || !submitButton) return;

    var SUPABASE_URL = typeof import.meta !== 'undefined' && import.meta.env && import.meta.env.PUBLIC_SUPABASE_URL ? import.meta.env.PUBLIC_SUPABASE_URL : '';
    var SUPABASE_ANON_KEY = typeof import.meta !== 'undefined' && import.meta.env && import.meta.env.PUBLIC_SUPABASE_ANON_KEY ? import.meta.env.PUBLIC_SUPABASE_ANON_KEY : '';

    form.addEventListener('submit', async function(event) {
      event.preventDefault();

      if (!SUPABASE_URL || !SUPABASE_ANON_KEY) {
        statusElement.textContent = 'Aún falta configurar el formulario.';
        statusElement.dataset.state = 'error';
        return;
      }

      var name = form.querySelector('[name="name"]').value;
      var attendance = form.querySelector('[name="attendance"]').value;
      var guests = form.querySelector('[name="guests"]').value;
      var prediction = form.querySelector('[name="prediction"]:checked') ? form.querySelector('[name="prediction"]:checked').value : '';
      var phone = form.querySelector('[name="phone"]').value;
      var message = form.querySelector('[name="message"]').value;

      submitButton.disabled = true;
      statusElement.textContent = 'Guardando confirmación...';
      statusElement.dataset.state = 'loading';

      try {
        var response = await fetch(SUPABASE_URL + '/rest/v1/rsvps', {
          method: 'POST',
          headers: {
            'apikey': SUPABASE_ANON_KEY,
            'Authorization': 'Bearer ' + SUPABASE_ANON_KEY,
            'Content-Type': 'application/json',
            'Prefer': 'return=minimal'
          },
          body: JSON.stringify({
            event: 'Gender Reveal Catherine & Josafat',
            name: name,
            attendance: attendance,
            guests: parseInt(guests, 10),
            prediction: prediction,
            phone: phone || null,
            message: message || null,
            user_agent: navigator.userAgent,
            source: 'invitation-web'
          })
        });

        if (response.ok || response.status === 201 || response.status === 204 || response.status === 0) {
          form.reset();
          form.hidden = true;
          var successCard = document.querySelector('[data-rsvp-success]');
          if (successCard) successCard.hidden = false;
        } else {
          throw new Error('Server responded with ' + response.status);
        }
      } catch (err) {
        statusElement.textContent = 'No se pudo guardar. Intenta de nuevo.';
        statusElement.dataset.state = 'error';
      } finally {
        submitButton.disabled = false;
      }
    });
  })();
</script>
